src/
├── api/          # 接口请求封装（对接后端SpringBoot的RESTful API）
│   ├── user.js   # 用户管理接口（注册/登录/头像上传）
│   ├── health.js # 健康档案接口（录入/查询/导出）
│   ├── order.js  # 服务订单接口（创建/支付/评价）
│   ├── alarm.js  # 紧急求助接口（SOS/报警查询）
│   ├── notice.js # 社区公告接口（查询/已读）
│   └── stats.js  # 数据统计接口（可视化/报表）
├── assets/       # 静态资源（适老化主题/css/图片）
│   ├── css/
│   │   ├── base.css    # 基础样式（重置/通用布局）
│   │   └── age-friendly.css # 适老化样式（大字体/高对比度）
│   └── images/         # 系统图标/默认头像/SOS按钮图片
├── components/   # 公共组件（适老化封装/复用组件）
│   ├── common/   # 通用组件（导航栏/页脚/加载/空状态）
│   ├── health/   # 健康档案组件（数据录入/趋势图表）
│   ├── order/    # 订单组件（服务卡片/订单列表/支付弹窗）
│   └── alarm/    # 报警组件（SOS悬浮按钮/报警提醒）
├── layout/       # 布局组件（老人端/管理员端/家属端）
├── pinia/        # 状态管理（用户信息/适老化配置/全局通知）
│   ├── userStore.js    # 用户状态（token/角色/信息）
│   └── settingStore.js # 适老化设置（字体大小/对比度）
├── router/       # 路由配置（分角色路由守卫/RBAC权限）
│   └── index.js
├── utils/        # 工具函数（请求封装/时间格式化/Excel导出）
│   ├── request.js # axios封装（请求拦截/响应拦截/Token携带）
│   ├── format.js  # 时间/数值格式化
│   └── export.js  # Excel导出工具（对接后端EasyExcel）
├── views/        # 页面视图（按六大模块划分，分角色展示）
│   ├── user/     # 用户管理（登录/注册/个人中心/头像上传）
│   ├── health/   # 健康档案（数据录入/历史查询/健康趋势）
│   ├── order/    # 服务商城（服务浏览/订单创建/支付/评价）
│   ├── alarm/    # 紧急求助（SOS/报警记录/处理）
│   ├── notice/   # 社区公告（公告列表/详情）
│   ├── stats/    # 数据统计（管理员可视化大屏/报表导出）
│   └── error/    # 错误页面（401/403/404）
├── App.vue       # 根组件（适老化样式切换/全局布局）
├── main.js       # 入口文件（Vue初始化/插件注册/路由挂载）
└── theme/        # 适老化主题配置（Element Plus主题定制）